<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER"/>
	<classpathentry excluding="controller/|model/|view/" kind="src" path="src/mitrivial"/>
	<classpathentry kind="src" path="src/mitrivial/controller"/>
	<classpathentry kind="src" path="src/mitrivial/model"/>
	<classpathentry kind="src" path="src/mitrivial/view"/>
	<classpathentry kind="src" path="src/main"/>
	<classpathentry excluding="mitrivial/|mitrivial/controller/|mitrivial/model/|mitrivial/view/|main/" kind="src" path="src"/>
	<classpathentry kind="output" path="bin"/>
</classpath>
